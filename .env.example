# ── B.U Eats — Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to git.

# Flask secret key for JWT tokens — change this to a long random string
JWT_SECRET_KEY=change-this-to-a-super-long-random-secret-in-production

# (Optional) Set to "production" on Railway, leave blank for local dev
FLASK_ENV=development
